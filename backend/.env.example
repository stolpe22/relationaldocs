# Ambiente
ENV=development

# Banco de dados
DB_TYPE=oracle
DB_HOST=localhost
DB_PORT=1521
DB_SERVICE=XEPDB1
DB_USER=
DB_PASSWORD=
DB_SCHEMA=

# SSH Tunnel
SSH_HOST=
SSH_PORT=22
SSH_USER=
SSH_PASSWORD=

# API
API_KEY=

# CORS (separado por vírgula; ignorado se ENV=development)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Connection Pool Oracle
DB_POOL_ENABLED=false
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_POOL_INCREMENT=1

# Oracle Instant Client (thick mode — necessário para bancos com verifier antigo)
ORACLE_INSTANT_CLIENT=/opt/oracle/instantclient_21_15
